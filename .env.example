# Environment Configuration for SharePoint Integration
# Copy this to .env.local and fill in your values

# ============================================
# AUTHENTICATION MODE
# ============================================
# Options: "microsoft" | "supabase" | "demo"
# Set to "microsoft" to enable SharePoint integration
NEXT_PUBLIC_AUTH_MODE=microsoft

# ============================================
# MICROSOFT AZURE AD CONFIGURATION
# ============================================
# From Azure Portal > App Registrations > Your App

# Application (client) ID
MICROSOFT_CLIENT_ID=your-client-id-here

# Client secret value (from Certificates & secrets)
MICROSOFT_CLIENT_SECRET=your-client-secret-here

# Directory (tenant) ID
MICROSOFT_TENANT_ID=your-tenant-id-here

# ============================================
# SHAREPOINT CONFIGURATION
# ============================================
# Use Graph Explorer to find these:
# https://developer.microsoft.com/graph/graph-explorer

# SharePoint site ID
# Query: GET /sites?search=Your Site Name
SHAREPOINT_SITE_ID=your-site-id-here

# Document library (drive) ID
# Query: GET /sites/{site-id}/drives
SHAREPOINT_DRIVE_ID=your-drive-id-here

# Optional root folder within the drive for app JSON storage
# Defaults to: kbm-construct-data
GLOBAL_STORAGE_FOLDER=kbm-construct-data

# ============================================
# APPLICATION URL
# ============================================
# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production (uncomment and update for deployment)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ============================================
# LEGACY SUPABASE (Optional - for migration)
# ============================================
# Only needed if running dual authentication during migration
# SUPABASE_URL=your-supabase-url
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-key
